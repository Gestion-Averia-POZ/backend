// Prisma schema for PostgreSQL with PostGIS support

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [postgis, uuidOssp(map: "uuid-ossp")]
}

// ROLES Y PERMISOS
model Role {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String   @unique @db.VarChar(50)
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relaciones
  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name           String   @unique @db.VarChar(100)
  description    String?
  resource       String?  @db.VarChar(100)
  permissionType String?  @map("permission_type") @db.VarChar(50)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relaciones
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz

  // Relaciones
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@map("role_permissions")
}

// USUARIOS
model User {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  roleId        String?  @map("role_id") @db.Uuid
  companyId     String?  @map("company_id") @db.Uuid
  name          String   @db.VarChar(100)
  lastname      String   @db.VarChar(100)
  phoneNumber   String?  @map("phone_number") @db.VarChar(20)
  email         String   @unique @db.VarChar(150)
  password      String
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relaciones
  role                Role?           @relation(fields: [roleId], references: [id])
  company             Company?        @relation(fields: [companyId], references: [id])
  reports             Report[]        @relation("UserReports")
  assignedReports     Report[]        @relation("AssignedManager")
  historyChanges      HistoryChange[]
  notifications       Notification[]
  requests            Request[]

  // Índices para optimizar consultas
  @@index([email]) // Ya existe como unique, pero explícito
  @@index([roleId]) // Para filtrar por rol
  @@index([companyId]) // Para filtrar por empresa
  @@index([isActive]) // Para filtrar usuarios activos
  @@index([createdAt]) // Para ordenar por fecha de creación
  @@index([roleId, isActive]) // Índice compuesto para consultas comunes
  @@map("users")
}

// GEOGRAFÍA
model Neighborhood {
  id        Int                                        @id @default(autoincrement())
  name      String                                     @db.VarChar(150)
  geom      Unsupported("geometry(Polygon, 4326)")
  totalArea Float?                                     @map("total_area")
  createdAt DateTime                                   @default(now()) @map("created_at") @db.Timestamptz

  // Relaciones
  reports Report[]

  @@map("neighborhood")
}

// EMPRESAS Y SERVICIOS
model Company {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String   @db.VarChar(150)
  description String?
  rif         String?  @unique @db.VarChar(50)
  address     String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relaciones
  companyCategories CompanyCategory[]
  reports           Report[]
  users             User[]

  // Índices
  @@index([isActive]) // Para filtrar empresas activas
  @@map("company")
}

model FailureType {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  description String?
  priority    String   @default("MEDIA") @db.VarChar(20) // BAJA, MEDIA, ALTA, CRITICA
  categoryId  String?  @map("category_id") @db.Uuid
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relaciones
  reports     Report[]
  category    Category? @relation(fields: [categoryId], references: [id])

  // Índices
  @@index([isActive]) // Para filtrar tipos de falla activos
  @@index([categoryId]) // Para filtrar por categoría
  @@map("failure_type")
}

model CompanyCategory {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  companyId  String   @map("company_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relaciones
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_category")
}

// CATEGORÍAS Y ESTADOS
model Category {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name      String   @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relaciones
  reports           Report[]
  companyCategories CompanyCategory[]
  failureTypes      FailureType[]

  // Índices
  @@index([name]) // Para búsquedas por nombre de categoría
  @@index([isActive]) // Para filtrar categorías activas
  @@map("category")
}

model State {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(50)
  colorHex  String?  @map("color_hex") @db.VarChar(7)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relaciones
  reports              Report[]
  requests             Request[]
  historyChangesPrev   HistoryChange[] @relation("PreviousState")
  historyChangesNew    HistoryChange[] @relation("NewState")

  // Índices
  @@index([name]) // Para búsquedas por nombre de estado
  @@map("state")
}

// REPORTES
model Report {
  id                String                                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  description       String?
  location          Unsupported("geometry(Point, 4326)")
  address           String?
  urlPhoto          String?                                @map("url_photo")
  priority          String?                                @db.VarChar(20) // BAJA, MEDIA, ALTA, CRITICA
  isActive          Boolean                                @default(true) @map("is_active")
  userId            String?                                @map("user_id") @db.Uuid
  assignedManagerId String?                                @map("assigned_manager_id") @db.Uuid
  stateId           Int?                                   @map("state_id")
  categoryId        String?                                @map("category_id") @db.Uuid
  companyId         String?                                @map("company_id") @db.Uuid
  failureTypeId     Int?                                   @map("failure_type_id")
  neighborhoodId    Int?                                   @map("neighborhood_id")
  createdAt         DateTime                               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime                               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relaciones
  user            User?           @relation("UserReports", fields: [userId], references: [id])
  assignedManager User?           @relation("AssignedManager", fields: [assignedManagerId], references: [id])
  state           State?          @relation(fields: [stateId], references: [id])
  category        Category?       @relation(fields: [categoryId], references: [id])
  company         Company?        @relation(fields: [companyId], references: [id])
  failureType     FailureType?    @relation(fields: [failureTypeId], references: [id])
  neighborhood    Neighborhood?   @relation(fields: [neighborhoodId], references: [id])
  historyChanges  HistoryChange[]

  // Índices para optimizar consultas de reportes
  @@index([userId]) // Para reportes por usuario
  @@index([assignedManagerId]) // Para reportes asignados
  @@index([stateId]) // Para filtrar por estado
  @@index([categoryId]) // Para filtrar por categoría
  @@index([companyId]) // Para reportes por empresa
  @@index([failureTypeId]) // Para reportes por tipo de falla
  @@index([neighborhoodId]) // Para reportes por barrio
  @@index([priority]) // Para filtrar por prioridad
  @@index([isActive]) // Para filtrar reportes activos
  @@index([createdAt]) // Para ordenar por fecha
  @@index([stateId, createdAt]) // Índice compuesto común
  @@index([userId, stateId]) // Para reportes de usuario por estado
  @@index([categoryId, stateId]) // Para reportes por categoría y estado
  @@index([priority, stateId]) // Para reportes por prioridad y estado
  @@map("report")
}

// HISTORIAL DE CAMBIOS
model HistoryChange {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  reportId      String   @map("report_id") @db.Uuid
  userId        String?  @map("user_id") @db.Uuid
  previousState Int?     @map("previous_state")
  newState      Int?     @map("new_state")
  comment       String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relaciones
  report        Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user          User?  @relation(fields: [userId], references: [id])
  previousStateRef State? @relation("PreviousState", fields: [previousState], references: [id])
  newStateRef   State? @relation("NewState", fields: [newState], references: [id])

  // Índices para historial
  @@index([reportId]) // Para historial por reporte
  @@index([userId]) // Para cambios por usuario
  @@index([createdAt]) // Para ordenar por fecha
  @@index([reportId, createdAt]) // Índice compuesto para historial ordenado
  @@map("history_change")
}

// NOTIFICACIONES
model Notification {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  title       String   @db.VarChar(255)
  description String   @db.Text
  type        String   @db.VarChar(50) // e.g., 'STATUS_CHANGE', 'REPORT_CANCELLED'
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relaciones
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Índices
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// SOLICITUDES (REQUESTS)
enum RequestType {
  REGISTRO
  DUDA
  BUG
}

model Request {
  id            String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  applicantName String      @map("applicant_name") @db.VarChar(150)
  type          RequestType
  description   String      @db.Text
  stateId       Int?        @map("state_id")
  userId        String?     @map("user_id") @db.Uuid
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relaciones
  state State? @relation(fields: [stateId], references: [id])
  user  User?  @relation(fields: [userId], references: [id])

  // Índices
  @@index([stateId])
  @@index([userId])
  @@index([createdAt])
  @@map("requests")
}
